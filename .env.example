# ── Required ──────────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather
TG_TOKEN=

# Your personal Telegram ID (get it from @userinfobot)
TG_ADMIN_ID=

# Hiddify panel URL (no trailing slash)
HIDDIFY_BASE_URL=https://your-panel.example.com

# The random path segment visible in your panel URL when logged in
# e.g. https://panel.example.com/2Y9W2nxrTf0t2OteiTW8BRZ/admin → 2Y9W2nxrTf0t2OteiTW8BRZ
HIDDIFY_ADMIN_PROXY=

# Admin API key from panel Settings
HIDDIFY_API_KEY=

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# SQLite database file path
# DB_PATH=data/bot.db

# Log level: debug | info | warn | error
# LOG_LEVEL=info

# Telegram long-polling timeout in seconds
# TG_TIMEOUT=10
