# Токен Telegram-бота из BotFather.
TG_TOKEN=replace_with_botfather_token

# Telegram ID администратора для /bind, /sync и /broadcast.
TG_ADMIN_ID=123456789

# URL панели Hiddify без слеша в конце.
HIDDIFY_BASE_URL=https://panel.example.com

# Случайный admin path из URL панели Hiddify.
HIDDIFY_ADMIN_PROXY=replace_with_admin_path

# Admin API key из панели Hiddify.
HIDDIFY_API_KEY=replace_with_api_key

# Необязательные значения, которые config.yml использует с дефолтами.
TG_TIMEOUT=10
DB_PATH=data/bot.db
LOG_LEVEL=info
